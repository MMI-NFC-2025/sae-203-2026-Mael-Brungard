---
import PbImage from "../../components/PbImage.astro";
import { getOneScene, getArtistsByScene } from "../../../backend/backend.mjs";
import Layout from "../../layouts/Layout.astro";
import EventCard from "../../components/EventCard.astro";
const { id } = Astro.params;
const scene = await getOneScene(id);
const artistes = await getArtistsByScene(id);
console.log(artistes);
---

<Layout
    title=`${scene.name}`
    desc=`Page dédiée à la description de ${scene.name}`
>
    <div class="relative w-full h-75 flex items-end">
        <PbImage
            record={scene}
            imageField={scene.image}
            classlist="w-full h-full object-cover absolute"
        />
        <div class="overlay absolute z-10 w-full h-full bg-black/40"></div>
        <h1 class="relative z-20 text-2xl font-bold text-white px-7 py-5">
            {scene.name}
        </h1>
    </div>
    <div class="p-10 flex flex-col gap-5">
        <div class="shadow-md/30 p-5 rounded-2xl">
            <p class="font-bold text-lg">Description</p>
            <p>
                {scene.desc}
            </p>
        </div>
        <div class="flex overflow-x-auto gap-5"></div>
    </div>

    <div class="flex flex-col p-10 gap-6">
        {artistes.map((artiste) => <EventCard art={artiste} />)}
    </div>
</Layout>
