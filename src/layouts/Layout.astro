---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title, desc } = Astro.props;
import "@fontsource/poppins";
import "@fontsource-variable/inter";
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon/favicons/favicon.ico?v=2" sizes="any" />
		<link rel="shortcut icon" href="/favicon/favicons/favicon.ico?v=2" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=1" />
		<link
			rel="icon"
			type="image/png"
			sizes="96x96"
			href="/favicon/favicons/favicon-96x96.png?v=1"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/favicon/favicons/apple-touch-icon.png?v=1"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={desc} />
	</head>
	<body>
		<Header title={title} />
		<slot />
		<Footer />
	</body>
</html>
