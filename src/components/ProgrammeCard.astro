---
const { event } = Astro.props;
import { fortmatDateHour } from "../../backend/backend.mjs";
import PbImage from "./PbImage.astro";
import Image from "astro/components/Image.astro";
import placeIcon from "../assets/icons/place.svg";
import timeIcon from "../assets/icons/time.svg";

const heure = fortmatDateHour(event.date);
---

<div
    class=`bg-white rounded-2xl shadow-lg flex items-center border border-cyan-400 border-3 overflow-hidden ${(event.genre === 'rock') ? 'border-orange-400' : (event.genre === 'pop') ? 'border-purple-400 ' : (event.genre === 'rap')? 'border-red-400 ' : 'border-blue-400 '}`
>
    <PbImage
        record={event}
        imageField={event.cover}
        classlist="w-1/2 h-full object-cover aspect-2/1"
    />
    <div class="p-4 flex flex-col items-center gap-3">
        <div class="text-xl font-bold text-black">{event.name}</div>
        <div class="flex flex-col items-center gap-2">
            <div
                class="text-base text-black flex gap-2 items-center font-semibold"
            >
                <Image src={placeIcon} alt="Place Icon" class="h-5 w-fit" />
                {event.expand.scene.name}
            </div>
            <div class="text-base text-black flex items-center gap-2">
                <Image src={timeIcon} alt="Place Icon" class="h-5 w-fit" />
                {heure}
            </div>
        </div>
    </div>
</div>
